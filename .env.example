# Core app
APP_ENV=development
APP_BASE_URL=http://localhost:8000
WEB_BASE_URL=
ENCRYPTION_KEY=
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
LOG_LEVEL=info

# Supabase and database
DATABASE_URL=postgresql://user:password@localhost:5432/voice_agent
SUPABASE_URL=
# Accepts either the legacy anon key or the new publishable key
SUPABASE_ANON_KEY=
# Accepts either the legacy service_role key or the new secret key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_SCHEMA=public

# Composio
COMPOSIO_API_KEY=
COMPOSIO_WEBHOOK_SECRET=
COMPOSIO_BASE_URL=
COMPOSIO_DEFAULT_ENTITY_PREFIX=voice-agent
COMPOSIO_GOOGLE_AUTH_CONFIG_ID=
COMPOSIO_GMAIL_AUTH_CONFIG_ID=
COMPOSIO_GOOGLECALENDAR_AUTH_CONFIG_ID=
COMPOSIO_MICROSOFT_AUTH_CONFIG_ID=

# Agent model
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Speech-to-text
STT_PROVIDER=groq
STT_MODEL=whisper-large-v3-turbo
GROQ_API_KEY=
DEEPGRAM_API_KEY=

# Text-to-speech
TTS_PROVIDER=google
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Kore
ELEVENLABS_API_KEY=

# Storage
STORAGE_PROVIDER=supabase
SUPABASE_STORAGE_BUCKET=voice-agent
STORAGE_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_ENDPOINT=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# Expo public
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_WS_URL=ws://localhost:8000
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_SENTRY_DSN=
